// ---------- Generator & Datasource ----------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------
enum UserType {
  Superadmin
  Admin
  Association
  Driver
  Controller
}

enum AssociationStatus {
  ACTIVE
  SUSPENDED
}

enum OwnerStatus {
  ACTIVE
  SUSPENDED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFFLINE
  SUSPENDED
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum VehicleAssociationStatus {
  ACTIVE
  SUSPENDED
  RESIGNED
}

// Coverage state for payments
enum PaymentStatus {
  ACTIVE
  INACTIVE
}

// Plan snapshot for ledger
enum PlanType {
  WEEKLY
  MONTHLY
}

// Payment source
enum PaymentSource {
  SYSTEM
  MANUAL
}

enum FeePlan {
  WEEKLY
  MONTHLY
}

enum PaymentMethod {
  CASH
  CARD
  BANK
  MOBILE
  OTHER
}

// ---------- Core Models ----------
model User {
  id             Int      @id @default(autoincrement())
  phone_number   String   @unique @db.VarChar(20)
  user_type      UserType
  name           String?  @db.VarChar(100)
  password_hash  String?  @db.VarChar(255)
  is_locked      Boolean  @default(false)
  association_id Int?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  association Association? @relation(fields: [association_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  tokens UserToken[]
  Driver Driver?

  // Back-relations for RouteAssignment
  assigned_route_assignments RouteAssignment[] @relation("assigner")
  approved_route_assignments RouteAssignment[] @relation("approver")

  // Payments created by this user (ledger)
  driver_payments_created DriverPayment[] @relation("payment_creator")

  @@map("users")
}

model UserToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("user_tokens")
}

model RevokedToken {
  jti        String   @id
  user_id    Int
  expires_at DateTime

  @@index([user_id])
  @@map("revoked_tokens")
}

model Association {
  id           Int               @id @default(autoincrement())
  name         String            @db.VarChar(100)
  phone_number String?           @db.VarChar(20)
  logo         String?           @db.VarChar(255)
  status       AssociationStatus @default(ACTIVE)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  users              User[]
  owners             Owner[]
  drivers            Driver[]
  vehicles           Vehicle[]
  assignments        VehicleAssignment[]
  route_quotas       RouteQuota[]
  route_assignments  RouteAssignment[]
  VehicleAssociation VehicleAssociation[]

  // Payments
  payment_policy  AssociationPolicy?
  driver_payments DriverPayment[]

  @@map("associations")
}

model Owner {
  id             Int         @id @default(autoincrement())
  association_id Int
  full_name      String      @db.VarChar(100)
  phone_number   String      @db.VarChar(20)
  status         OwnerStatus @default(ACTIVE)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  association Association @relation(fields: [association_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicles    Vehicle[]

  @@unique([association_id, phone_number])
  @@map("owners")
}

model Driver {
  id             Int          @id @default(autoincrement())
  user_id        Int          @unique
  association_id Int
  full_name      String       @db.VarChar(100)
  license_no     String?
  license_expiry DateTime?
  phone_number   String       @db.VarChar(20)
  status         DriverStatus @default(AVAILABLE)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  // Plan & payment state
  is_weekly           Boolean       @default(false) // false = monthly, true = weekly
  payment_status      PaymentStatus @default(INACTIVE)
  active_until_date   DateTime?     @db.Date
  interest_accrued    Decimal       @default(0.00) @db.Decimal(10, 2)
  last_accrual_date   DateTime?     @db.Date
  last_accrual_amount Decimal?      @db.Decimal(10, 2)

  user            User                @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  association     Association         @relation(fields: [association_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignments     VehicleAssignment[]
  RouteAssignment RouteAssignment[]

  // Ledger
  payments DriverPayment[]

  @@unique([association_id, phone_number])
  @@index([association_id, is_weekly, active_until_date])
  @@index([payment_status])
  @@index([last_accrual_date])
  @@map("drivers")
}

model Vehicle {
  id             Int           @id @default(autoincrement())
  plate_number   String        @unique @db.VarChar(20)
  libre_no       String?
  owner_id       Int
  association_id Int
  make           String?
  model          String?
  color          String?
  capacity       Int?
  status         VehicleStatus @default(ACTIVE)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  deleted_at     DateTime?

  owner              Owner                @relation(fields: [owner_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  association        Association          @relation(fields: [association_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignments        VehicleAssignment[]
  VehicleAssociation VehicleAssociation[]
  RouteAssignment    RouteAssignment[]

  @@map("vehicles")
}

model VehicleAssociation {
  id             Int                      @id @default(autoincrement())
  association_id Int
  vehicle_id     Int
  started_at     DateTime                 @default(now())
  ended_at       DateTime?
  status         VehicleAssociationStatus @default(ACTIVE)

  association Association @relation(fields: [association_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicle     Vehicle     @relation(fields: [vehicle_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([association_id])
  @@index([vehicle_id, ended_at])
  @@map("vehicle_associations")
}

model VehicleAssignment {
  id             Int       @id @default(autoincrement())
  driver_id      Int
  vehicle_id     Int
  association_id Int
  active         Boolean   @default(true)
  started_at     DateTime  @default(now())
  ended_at       DateTime?

  driver      Driver      @relation(fields: [driver_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vehicle     Vehicle     @relation(fields: [vehicle_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  association Association @relation(fields: [association_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([driver_id, vehicle_id, active])
  @@index([driver_id])
  @@index([vehicle_id])
  @@index([association_id])
  @@map("vehicle_assignments")
}

model RouteGroup {
  id          Int      @id @default(autoincrement())
  route_group String   @db.VarChar(100)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  routes Route[]

  @@map("route_groups")
}

model Route {
  id             Int      @id @default(autoincrement())
  route_group_id Int
  departure      String
  arrival        String
  kilometer      Decimal? @db.Decimal(6, 2)
  tariff         Decimal? @db.Decimal(6, 2)
  updated_at     DateTime @updatedAt
  created_at     DateTime @default(now())

  route_group       RouteGroup        @relation(fields: [route_group_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  route_quotas      RouteQuota[]
  route_assignments RouteAssignment[]

  @@index([route_group_id])
  @@map("routes")
}

enum RouteAssignmentStatus {
  Approved
  Pending
}

model RouteQuota {
  id             Int      @id @default(autoincrement())
  association_id Int
  route_id       Int
  start_date     DateTime
  end_date       DateTime
  no_vehicles    Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  association Association @relation(fields: [association_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  route       Route       @relation(fields: [route_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  assignments RouteAssignment[]

  @@index([association_id, route_id, start_date, end_date])
  @@map("route_quotas")
}

model RouteAssignment {
  id             Int                   @id @default(autoincrement())
  route_id       Int
  driver_id      Int
  vehicle_id     Int
  association_id Int
  start_date     DateTime
  end_date       DateTime
  status         RouteAssignmentStatus @default(Pending)
  is_weekly      Boolean
  created_at     DateTime              @default(now())
  updated_at     DateTime              @updatedAt

  assigned_by_user_id Int
  approved_by_user_id Int?
  approved_at         DateTime?
  route_quota_id      Int?

  route       Route       @relation(fields: [route_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  driver      Driver      @relation(fields: [driver_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vehicle     Vehicle     @relation(fields: [vehicle_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  association Association @relation(fields: [association_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  route_quota RouteQuota? @relation(fields: [route_quota_id], references: [id], onDelete: SetNull)

  assigned_by User  @relation("assigner", fields: [assigned_by_user_id], references: [id], onDelete: Restrict)
  approved_by User? @relation("approver", fields: [approved_by_user_id], references: [id], onDelete: SetNull)

  @@unique([route_id, driver_id, vehicle_id])
  @@index([association_id, route_id, start_date, end_date])
  @@index([assigned_by_user_id])
  @@index([approved_by_user_id])
  @@map("route_assignments")
}

// ===== New tables =====
model AssociationPolicy {
  id                 Int     @id @default(autoincrement())
  association_id     Int     @unique
  weekly_fee         Decimal @db.Decimal(10, 2)
  monthly_fee        Decimal @db.Decimal(10, 2)
  daily_fine_percent Decimal @db.Decimal(5, 4) // e.g. 0.20 for 20%

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  association Association @relation(fields: [association_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("association_policies")
}

model DriverPayment {
  id                 Int @id @default(autoincrement())
  association_id     Int
  driver_id          Int
  created_by_user_id Int

  fee_plan           FeePlan
  prepaid_qty        Int            @default(0)
  amount             Decimal        @db.Decimal(12, 2)
  covered_start_date DateTime
  covered_end_date   DateTime
  paid_at            DateTime       @default(now())
  payment_method     PaymentMethod?

  association Association @relation(fields: [association_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  driver      Driver      @relation(fields: [driver_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  creator     User        @relation("payment_creator", fields: [created_by_user_id], references: [id], onDelete: Restrict)

  @@index([association_id])
  @@index([driver_id])
  @@map("driver_payments")
}
